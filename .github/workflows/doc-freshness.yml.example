# Doc Freshness — skeleton workflow for AAP Console.
#
# Copy this file to `doc-freshness.yml` (drop the `.example` suffix) after
# deciding that soft doc-drift comments should run in GitHub Actions.
#
# This workflow is intentionally a soft warning. It surfaces implementation-doc,
# roadmap/status, and gate drift fast so the author can fix or ack in the same PR.
#
# Untrusted GitHub event input flows only through env: blocks. Do not inline
# `${{ ... }}` expressions into shell `run:` commands.

name: Doc Freshness

on:
  pull_request:
    types: [opened, synchronize, reopened, ready_for_review]

permissions:
  contents: read
  pull-requests: write

jobs:
  check:
    if: github.event.pull_request.draft == false
    runs-on: ubuntu-latest
    timeout-minutes: 3
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Compute changed paths vs base
        id: diff
        env:
          PR_BASE_REF: ${{ github.event.pull_request.base.ref }}
        run: |
          set -euo pipefail
          git fetch --no-tags --depth=1 origin "$PR_BASE_REF"
          CHANGED=$(git diff --name-only "origin/${PR_BASE_REF}...HEAD")
          {
            echo "changed<<EOF"
            echo "$CHANGED"
            echo "EOF"
          } >> "$GITHUB_OUTPUT"

      - name: Detect doc-touching code changes
        id: detect
        env:
          CHANGED: ${{ steps.diff.outputs.changed }}
        run: |
          set -euo pipefail
          missing=()

          touched_src=$(printf '%s\n' "$CHANGED" | grep -E '^(app|config|lib|bin)/|^(Gemfile|Gemfile.lock|Dockerfile|config\.ru)$' || true)
          touched_migrations=$(printf '%s\n' "$CHANGED" | grep -E '^db/migrate/' || true)

          touched_any_thin_doc=$(printf '%s\n' "$CHANGED" | grep -E '^docs/current/(RUNTIME|CODE_MAP|DATA_MODEL|TESTING|OPERATIONS)\.md$' || true)
          touched_data_doc=$(printf '%s\n' "$CHANGED" | grep -E '^docs/current/DATA_MODEL\.md$' || true)
          touched_roadmap_doc=$(printf '%s\n' "$CHANGED" | grep -E '^docs/04_IMPLEMENTATION_PLAN\.md$' || true)
          touched_current_state=$(printf '%s\n' "$CHANGED" | grep -E '^docs/context/current-state\.md$' || true)
          touched_acceptance_doc=$(printf '%s\n' "$CHANGED" | grep -E '^docs/06_ACCEPTANCE_TESTS\.md$' || true)
          touched_generated=$(printf '%s\n' "$CHANGED" | grep -E '^docs/generated/' || true)
          touched_adr=$(printf '%s\n' "$CHANGED" | grep -E '^docs/adr/' || true)

          if [ -n "$touched_src" ] &&
             [ -z "$touched_any_thin_doc" ] &&
             [ -z "$touched_roadmap_doc" ] &&
             [ -z "$touched_current_state" ] &&
             [ -z "$touched_acceptance_doc" ] &&
             [ -z "$touched_adr" ]; then
            missing+=("Source code changed -> update matching docs: \`docs/current/\` for implemented behavior, \`docs/04_IMPLEMENTATION_PLAN.md\` for slice/evidence changes, \`docs/context/current-state.md\` for active position changes, \`docs/06_ACCEPTANCE_TESTS.md\` for gate changes, or add an ADR.")
          fi

          if [ -n "$touched_migrations" ] && [ -z "$touched_data_doc" ] && [ -z "$touched_generated" ] && [ -z "$touched_adr" ]; then
            missing+=("Migrations changed -> update \`docs/current/DATA_MODEL.md\` and regenerate/commit any relevant \`docs/generated/\` output if a generator exists.")
          fi

          if [ ${#missing[@]} -eq 0 ]; then
            echo "missing=" >> "$GITHUB_OUTPUT"
          else
            {
              echo "missing<<EOF"
              for m in "${missing[@]}"; do
                echo "- $m"
              done
              echo "EOF"
            } >> "$GITHUB_OUTPUT"
          fi

      - name: Comment on PR if docs may be stale
        if: steps.detect.outputs.missing != ''
        uses: actions/github-script@v7
        env:
          MISSING: ${{ steps.detect.outputs.missing }}
        with:
          script: |
            const missing = process.env.MISSING || '';
            const marker = '<!-- doc-freshness-check -->';
            const body = [
              marker,
              '### Doc freshness check',
              '',
              'Code changes were detected that may require roadmap/status, gate, thin-doc, generated-doc, or ADR updates.',
              '',
              missing,
              '',
              'Policy: `docs/DOCUMENTATION.md`. This comment is automated. If the change is intentional, check "No doc impact" in the PR template and add a brief reason.',
            ].join('\n');

            const { data: comments } = await github.rest.issues.listComments({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
            });
            const existing = comments.find(c => c.body && c.body.startsWith(marker));
            if (existing) {
              await github.rest.issues.updateComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                comment_id: existing.id,
                body,
              });
            } else {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: context.issue.number,
                body,
              });
            }
