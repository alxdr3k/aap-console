<% content_for :title, "New Organization | AAP Console" %>

<section class="page">
  <div class="breadcrumbs">Console &gt; Organizations &gt; 새 Organization</div>

  <header class="page-header">
    <div>
      <h1 class="page-title">새 Organization 생성</h1>
      <p class="page-description">Organization 이름과 초기 관리자를 지정합니다.</p>
    </div>
  </header>

  <%= form_with model: @organization, url: organizations_path, class: "form" do |form| %>
    <% if @errors.present? %>
      <ul class="error-list">
        <% @errors.each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    <% end %>

    <div class="field">
      <%= form.label :name, "이름" %>
      <%= form.text_field :name, required: true, autofocus: true %>
    </div>

    <div class="field">
      <%= form.label :description, "설명" %>
      <%= form.textarea :description %>
    </div>

    <div class="field">
      <%= form.label :initial_admin_user_sub, "초기 관리자 user_sub" %>
      <%= form.text_field :initial_admin_user_sub %>
    </div>

    <div class="form-actions">
      <%= link_to "취소", organizations_path, class: "button button--ghost" %>
      <%= form.submit "생성", class: "button" %>
    </div>
  <% end %>
</section>
