<%= form_with url: organization_projects_path(@organization.slug),
              scope: :project,
              method: :post,
              class: "form form--wide" do |form| %>
  <div class="form-grid form-grid--two">
    <div class="field">
      <%= form.label :name, "이름 *" %>
      <%= form.text_field :name, value: @project.name, required: true, autocomplete: "off" %>
    </div>

    <div class="field">
      <%= form.label :s3_retention_days, "S3 Retention (일)" %>
      <%= form.number_field :s3_retention_days,
                            value: @s3_retention_days,
                            min: 1,
                            max: 3650,
                            step: 1 %>
    </div>
  </div>

  <div class="field">
    <%= form.label :description, "설명" %>
    <%= form.text_area :description, value: @project.description, maxlength: 500 %>
  </div>

  <section class="form-section">
    <h2 class="form-section__title">인증 설정</h2>
    <div class="radio-grid">
      <label class="radio-card">
        <%= form.radio_button :auth_type, "oidc", checked: @selected_auth_type == "oidc" %>
        <span>
          <strong>OIDC</strong>
          <small>OpenID Connect</small>
        </span>
      </label>

      <label class="radio-card">
        <%= form.radio_button :auth_type, "oauth", checked: @selected_auth_type == "oauth" %>
        <span>
          <strong>OAuth</strong>
          <small>PKCE S256 (Public Client)</small>
        </span>
      </label>

      <% %w[saml pak].each do |auth_type| %>
        <label class="radio-card radio-card--disabled">
          <%= radio_button_tag "project[auth_type_disabled_#{auth_type}]", auth_type, false, disabled: true %>
          <span>
            <strong><%= auth_type.upcase %></strong>
            <small>준비 중</small>
          </span>
        </label>
      <% end %>
    </div>
  </section>

  <section class="form-section">
    <h2 class="form-section__title">LiteLLM Config</h2>

    <div class="field">
      <span class="field__label">모델 선택 *</span>
      <div class="option-grid">
        <% @available_models.each do |model| %>
          <label class="checkbox-tile">
            <%= check_box_tag "project[models][]", model, @selected_models.include?(model) %>
            <span><%= model %></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="field">
      <span class="field__label">가드레일</span>
      <div class="option-grid">
        <% @available_guardrails.each do |guardrail| %>
          <label class="checkbox-tile">
            <%= check_box_tag "project[guardrails][]", guardrail, @selected_guardrails.include?(guardrail) %>
            <span><%= guardrail %></span>
          </label>
        <% end %>
      </div>
    </div>
  </section>

  <div class="form-actions">
    <%= link_to "취소", organization_projects_path(@organization.slug), class: "button button--secondary" %>
    <%= form.submit "생성", class: "button" %>
  </div>
<% end %>
